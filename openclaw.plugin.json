{
  "id": "feishu-classmate",
  "name": "Feishu Classmate",
  "description": "实验室办公场景下的飞书同学:Temi + 飞书 + MetaClaw 的智能伙伴",
  "skills": ["./skills"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "feishu": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "appId": { "type": "string", "description": "飞书自建应用 App ID,优先从 FEISHU_APP_ID 环境变量读取" },
          "appSecret": { "type": "string", "description": "飞书自建应用 App Secret,优先从 FEISHU_APP_SECRET 环境变量读取" },
          "domain": { "type": "string", "enum": ["feishu", "lark"], "default": "feishu" }
        }
      },
      "bitable": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "appToken": { "type": "string", "description": "多维表 app_token,由 setup 首次运行后自动填入" },
          "tableIds": {
            "type": "object",
            "properties": {
              "projects": { "type": "string" },
              "gantt": { "type": "string" },
              "equipment": { "type": "string" },
              "research": { "type": "string" }
            }
          }
        }
      },
      "docs": {
        "type": "object",
        "properties": {
          "publicProjects": { "type": "string" },
          "privateProjects": { "type": "string" },
          "researchReports": { "type": "string" },
          "dailyRecord": { "type": "string" }
        }
      },
      "labInfo": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "default": "Our Lab" },
          "supervisorName": { "type": "string" },
          "memberCount": { "type": "integer", "default": 6 },
          "broadcastChatId": { "type": "string", "description": "实验室大群 chat_id,广播用" },
          "specialAreas": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "narration": { "type": "string" }
              },
              "required": ["name", "narration"]
            }
          }
        }
      },
      "temi": {
        "type": "object",
        "properties": {
          "sidecarUrl": { "type": "string", "default": "http://127.0.0.1:8091" },
          "mockMode": { "type": "boolean", "default": true }
        }
      },
      "schedules": {
        "type": "object",
        "properties": {
          "ganttCheckCron": { "type": "string", "default": "0 9 * * *" },
          "equipmentPatrolCron": { "type": "string", "default": "30 8 * * *" },
          "idleLoopCron": { "type": "string", "default": "0 22 * * 1-5" }
        }
      },
      "supervision": {
        "type": "object",
        "properties": {
          "defaultIntervalMinutes": { "type": "integer", "default": 10 },
          "maxDurationHours": { "type": "integer", "default": 8 }
        }
      }
    }
  }
}
